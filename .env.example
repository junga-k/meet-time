DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-me-to-a-long-random-string"
# Optional — 회의록 "AI 초안 생성" 기능에만 사용. 미설정 시 버튼은 노출되지만 클릭 시 안내 토스트만 표시됨.
# ANTHROPIC_API_KEY=

# Optional — 설정하면 로컬 SQLite 파일 대신 Turso(원격 libSQL)로 연결됨(src/lib/prisma.ts 참고).
# Vercel 등 서버리스 배포 환경에서는 파일 기반 SQLite가 동작하지 않으므로 필수로 설정해야 함.
# 값 발급: `turso db show <db-name> --url`, `turso db tokens create <db-name>`
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
